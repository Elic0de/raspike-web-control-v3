# Web UI listener
HOST=0.0.0.0
PORT=3000

# UDP telemetry listener on the machine running this app
TELEMETRY_HOST=0.0.0.0
TELEMETRY_PORT=8765

# Default: run this app on the remote RasPi and use services on the same host.
RASPIKE_TARGET=remote

# Optional local PC mode:
# RASPIKE_TARGET=local
# RASPIKE_REMOTE_HOST=<RASPI_IP_ADDRESS>

# TCP control bridge. Leave unset in remote mode to use 127.0.0.1.
# BRIDGE_HOST=<RASPI_IP_ADDRESS>
BRIDGE_PORT=8766
BRIDGE_RETRY_SEC=1

# Optional etrobo2026 CSV used for calibration/state telemetry.
# ETROBO_TELEMETRY_CSV=/home/raspike/etrobo2026/logs/latest.csv

# Optional: force the browser WebSocket endpoint.
# Leave unset to use ws(s)://<current-host>/ws.
# VITE_GATEWAY_WS_URL=ws://127.0.0.1:3000/ws
