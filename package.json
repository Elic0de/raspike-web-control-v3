{
  "name": "raspike-web-control-v3",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "dev:gateway": "PORT=3001 node server.mjs",
    "build": "tsc --noEmit && vite build",
    "build:dist-zip": "pnpm build && rm -rf release && mkdir -p release && zip -qr release/dist.zip dist server.mjs package.json README.md .env.example",
    "start": "NODE_ENV=production node server.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5",
    "shadcn": "^4.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7"
  }
}
